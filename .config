# Non-secret configuration for futuresooth. This file IS committed to the repo.
# Secrets (API keys, tokens) go in .env (gitignored) instead.
# Any value here can be overridden by a real environment variable of the same name.

# --- API service (cmd/server) ---
# HTTP listen address for the API (default :8080)
HTTP_ADDR=:8080
# Directory where the on-disk data cache + CSV/JSON exports are written (default ./data)
DATA_DIR=./data
# How often the background refresher re-pulls all series (default 360h, ~twice a
# month). BLS releases monthly, so this is intentionally lazy. Go duration syntax.
REFRESH_INTERVAL=360h
# First year of history to request from BLS (default 1948). End year is this year.
START_YEAR=1948

# --- Web service (cmd/web) ---
# HTTP listen address for the web UI (default :3000)
FRONTEND_ADDR=:3000
# Base URL of the API service the web UI fetches from (default http://localhost:8080)
BACKEND_URL=http://localhost:8080

# --- Secrets (set these in .env, not here) ---
# BLS_API_KEY   BLS API v2 registration key (optional; keyless = lower limits).
#               Register free: https://data.bls.gov/registrationEngine/
# ADMIN_TOKEN   If set, enables POST /admin/refresh (X-Admin-Token header).
